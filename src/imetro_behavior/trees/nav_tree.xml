<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="Sequence">
      <CreatePoseStamped
        name="set_nav_pose"
        position_xyz="0.5, 0.0, 0.0"
        orientation_wxyz="1.0, 0.0, 0.0, 0.0"
        frame="map"
        msg="{nav_pose}"
      />
      <NavigateToPoseBehavior
        name="nav_to_pose"
        action_name="/phoebe/navigate_to_pose"
        action_server_timeout="3.0"
        goal_pose="{nav_pose}"
      />
    </Sequence>
  </BehaviorTree>
</root>
